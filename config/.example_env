# Application configuration
APP_PORT=8080
ENV=development

# Security configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
JWT_EXPIRY_MINUTES=60

# Rate limiting
RATE_LIMIT=100

# Database configuration (PostgreSQL)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=3001
DB_USER=admin
DB_PASS=Admin123
DB_NAME=app_db
SSL_MODE=disable

# Logging
LOG_LEVEL=info